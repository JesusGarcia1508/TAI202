# Variables de entorno para la API
# Copiar este archivo a .env.local para desarrollo local

# Base de datos PostgreSQL
DATABASE_URL=postgresql://admin:123456@localhost:5434/DB_miapi

# Puerto de la API
API_PORT=5000

# Host de la API
API_HOST=0.0.0.0

# Credenciales por defecto para autenticación HTTP Basic (DELETE)
AUTH_USERNAME=jesus
AUTH_PASSWORD=123456

# Modo de desarrollo
DEBUG=True
